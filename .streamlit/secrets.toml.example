# Snowflake connection template for snowflake-connector-python.
# Copy this file to secrets.toml and replace placeholder values with your credentials.
# secrets.toml is gitignored and must never be committed.

account = "your_account_identifier"
user = "your_username"
password = "your_password"
role = "your_role"
warehouse = "your_warehouse"
database = "SUPPLY_CHAIN_DB"
schema = "BRONZE_GOLD"
